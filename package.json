{
  "name": "tspp",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch run .tspp/run.ts",
    "once": "bun run .tspp/run.ts",
    "prod": "bun run .tspp/run.ts",
    "build": "bun run .tspp/build.ts",
    "format": "biome check --write .",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@biomejs/biome": "^2.0.5",
    "bun-plugin-auto-imports": "^0.4.1",
    "typescript": "^5.9.2"
  }
}
