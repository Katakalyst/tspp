{
  "name": "tspp",
  "type": "module",
  "private": true,
  "imports": {
    "#tspp/types": "./.tspp/runtime/types.ts"
  },
  "scripts": {
    "dev": "bun --watch run .tspp/cli/run.ts",
    "once": "bun run .tspp/cli/run.ts",
    "prod": "bun run .tspp/cli/run.ts",
    "build": "bun run .tspp/cli/build.ts",
    "format": "biome check --write --config-path .tspp/config/biome.check.json .",
    "check": "biome check --config-path .tspp/config/biome.check.json . && eslint . && tsc --noEmit && bun test --pass-with-no-tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "bun-plugin-auto-imports": "^0.4.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "immutable": "^5.1.5"
  }
}
