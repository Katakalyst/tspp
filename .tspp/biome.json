{
  "root": false,
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.json",
      "**/*.md",
      ".vscode/*.json",
      "!!**/.tspp/globals.user.d.ts",
      "!!**/.tspp/types.d.ts",
      "!!**/dist"
    ]
  }
}
